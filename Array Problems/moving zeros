//SWAPPING

class Solution {
public:
    void moveZeroes(vector<int>& nums) {

        int j = 0;
        int n = nums.size();
        for(int i = 0; i < n; i++){
            if(nums[i] != 0){
                swap(nums[j],nums[i]);
                j++;
            }

        }
    }
};
    
