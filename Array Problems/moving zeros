#include<iostream>
using namespace std;

void movingzeros(int arr[], int n){
    
    int j = 0;
    
    for(int i = 0; i < n; i++){
        if(arr[i] != 0){
            arr[j] = arr[i];
            j++;
        }
    }
    
    while(j<n){
        arr[j] = 0;
        j++;
    }
    
}

