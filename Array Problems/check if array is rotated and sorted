#include<iostream>
using namespace std;

bool check(int arr[], int n){
    
    int breakpoint = 0;
    
    for(int i = 0; i < n; i++){
        if(arr[i] > arr[(i+1) % n]){
            breakpoint++;
        }
        
    }
    
    return breakpoint <= 1;
}

int main(){
    
    int n; 
    cin >> n;
    
    int arr[100];
    for(int i = 0; i < n; i++){
        cin >> arr[i];
    }
    
    cout << check(arr,n);
}



