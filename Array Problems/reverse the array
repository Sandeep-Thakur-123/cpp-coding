#include<iostream>
#include<vector>
#include<utility>
using namespace std;

vector<int> reverse(vector<int> v, int n){
    int i = 0;
    int j = n-1;
    
    while(i < j){
    swap(v[i], v[j]);
    i++;
    j--;
    }
    
    return v;
    
}

int main(){
    
    int n = 5;
                      // int arr[n]
                                                        (This is the Standarad way of taking the input in the array.)
                      // for(int i = 0; i < n; i ++ ){
                      //     cin >> arr[i];
                      // }
    
    vector<int>v(n);
    for(int &x : v){
        cin >> x;
    }
    
    v = reverse(v,n);
    
    for(int x : v){
        cout << x<<" ";
    }
}
    
