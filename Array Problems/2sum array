#include<iostream>
using namespace std;

pair<int,int> twosum(int arr[], int n, int target){
    for(int i = 0; i < n; i++){
        for(int j = i+1; j < n; j++){
            if(arr[i] +arr[j] == target){
                return {i,j};
            }
        }
    }
    
    return {-1,-1};
}

int  main(){
    int n;
    cin >> n;
    
    int target;
    cin >> target;
    
    int arr[100];
    for(int i = 0; i < n; i++){
        cin >> arr[i];    
    }
    
   pair<int,int>result = twosum(arr, n, target);
   cout << result.first <<" "<< result.second;
}

// In this part we did sorting and maintained the original order of indices also


#include<iostream>
#include<algorithm>
using namespace std;

pair<int,int> twosum(pair<int,int> arr[], int n, int target){
    int j = n-1;
    for(int i = 0; i < n; ){
        if(arr[i].first + arr[j].first == target){
          return {arr[i].second,arr[j].second};  
        }
        
        else if(arr[i].first + arr[j].first > target){
            j--;
        }
        
        else if(arr[i].first + arr[j].first < target){
            i++;
        }
    }
    
    return {-1,-1};
}

int main(){
    int n;
    cin >> n;
    
    int target;
    cin >> target;
    
    pair<int,int> arr[100];
    for(int i = 0; i < n; i++){
        cin >> arr[i].first;
        arr[i].second = i;
    }
    
    sort(arr,arr+n);
    
   pair<int,int> result = twosum(arr,n,target);
   
   cout << result.first <<" " << result.second;
}
