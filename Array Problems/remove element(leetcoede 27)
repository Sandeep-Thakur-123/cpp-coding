#include<bits/stdc++.h>
using namespace std;

int removeelement(int arr[], int n, int val){
    int k = 0;
    for(int i = 0; i < n; i++){
        if(arr[i] != val){
            arr[k] = arr[i];
            k++;}
    }
    return k;

}

int main(){
    int n;
    cin >> n;
    
    int arr[100];
    for(int i = 0; i < n ; i++){
        cin >> arr[i];
    }
    
    int val;
    cin >> val;
    
    int result = removeelement(arr,n,val);
    cout << result << endl;
    
    for(int i = 0; i < result; i++){
        cout << arr[i];
    }
}


