#include<iostream>
#include<vector>
#include<utility>
using namespace std;

vector<int> reverse(vector<int> v,int i, int j){
    
    if(i >= j){
        return v;
    }
    
    else{
        swap(v[i],v[j]);
        return reverse(v,i+1,j-1);
    }
    
}

int main(){
    
    int n = 5;
    // int arr[n]
    
    // for(int i = 0; i < n; i ++ ){
    //     cin >> arr[i];
    // }
    
    vector<int>v(n);
    for(int &x : v){
        cin >> x;
    }
    
    int i = 0;
    int j = n-1;
    
    v = reverse(v,i,j);
    
    for(int x : v){
        cout << x<<" ";
    }
}
    
