#include<iostream>
#include<vector>
#include<algorithm>
#include<utility>
using namespace std;

bool permutation(vector<int>&nums, int n){
    
    int i  = n-1;
    while(i >= 0){
        if(i == 0){
            reverse(nums.begin(), nums.end());
            return false;
        }
        
        else if(nums[i-1] < nums[i]){
            int pivot = i-1;
            for(int j = n-1; j > pivot; j--){
                if(nums[j] > nums[pivot]){
                    swap(nums[pivot], nums[j]);
                    reverse((nums.begin()+pivot+1), nums.end());
                    return true;
                }
            }
        }
        
        else{
             i--;
        }
    }
    
    return false;
}

int main(){
    
    int n;
     cin >> n;
    
    vector<int>v(n);
    for(int &x : v){
        cin >> x;
    }
    
    sort(v.begin(), v.end());
    
    while (true) {

        // Print current permutation
        for (int x : v)
            cout << x << " ";

        cout << endl;

        // If there is no next permutation, stop
        if (!permutation(v,n))
            break;
    }
}

