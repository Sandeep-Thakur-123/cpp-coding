#include<iostream>
using namespace std;

int binarysearch(int arr[], int start, int end, int target){
    
    if(start > end){
        return -1;
    }
    
    int mid = start + (end-start)/2;
    
    if(arr[mid] == target){
        return mid;
    }
    
    else if(arr[mid] > target){
        return(start,mid-1,target);
    }
    
    else if(arr[mid] < target){
        return (mid+1,end,target);
    }
    
}

int main(){
    
    int n;
    cin >> n;
    
    int target;
    cin >> target;
    
    int arr[100];
    for(int i = 0; i < n; i++){
        cin >> arr[i];
    }
    
    int start = 0;
    int end = n-1;
    
    cout << binarysearch(arr, start, end, target);
}
